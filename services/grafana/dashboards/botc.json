{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "RUNNING" }, "1": { "color": "red", "text": "PAUSED" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT (control_value = 'true')::int FROM bot_control WHERE control_key = 'bot_paused'",
          "refId": "A"
        }
      ],
      "title": "Bot status",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "Market Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 1 }, "overrides": [] },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 5 },
      "id": 3,
      "options": {
        "mode": "candles",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": { "up": "green", "down": "red" },
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, open::float AS open, high::float AS high, low::float AS low, close::float AS close FROM ohlc_data WHERE pair = '$pair' AND $__unixEpochFilter(\"time\") ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Price",
      "type": "candlestick"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "unit": "locale", "decimals": 1, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 5 },
      "id": 4,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, atr::float AS atr FROM ohlc_data WHERE pair = '$pair' AND $__unixEpochFilter(\"time\") AND atr IS NOT NULL ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "ATR",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*price.*" },
            "properties": [
              { "id": "unit", "value": "locale" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "id": 5,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT pair, side, entry_price, activation_price, trailing_price, stop_price, updated_at FROM trailing_state WHERE closing_order_id IS NULL AND pair = '$pair' ORDER BY pair",
          "refId": "A"
        }
      ],
      "title": "Open positions",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 102,
      "title": "Performance Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 18, "w": 12, "x": 0, "y": 22 },
      "id": 8,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at AS time, SUM(pnl_percent::float8) OVER (ORDER BY closed_at) AS cumulative_pnl FROM closed_positions WHERE pair = '$pair' ORDER BY closed_at",
          "refId": "A"
        }
      ],
      "title": "Cumulative PnL",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "gain" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "loss" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 22 },
      "id": 14,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at AS time, CASE WHEN pnl_percent >= 0 THEN pnl_percent::float8 END AS gain FROM closed_positions WHERE pair = '$pair' AND $__timeFilter(closed_at) ORDER BY closed_at",
          "refId": "A"
        },
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at AS time, CASE WHEN pnl_percent < 0 THEN pnl_percent::float8 END AS loss FROM closed_positions WHERE pair = '$pair' AND $__timeFilter(closed_at) ORDER BY closed_at",
          "refId": "B"
        }
      ],
      "title": "PnL per close",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*price.*" },
            "properties": [
              { "id": "unit", "value": "locale" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pnl_percent" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] } },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 31 },
      "id": 13,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at, side, entry_price::float8, closing_price::float8, pnl_percent::float8 FROM closed_positions WHERE pair = '$pair' AND $__timeFilter(closed_at) ORDER BY closed_at DESC",
          "refId": "A"
        }
      ],
      "title": "Closed positions",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 103,
      "title": "Sessions",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 41 },
      "id": 10,
      "options": { "barWidth": 0.6, "fillOpacity": 80, "groupWidth": 0.7, "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" }, "xField": "status" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT status, COUNT(*) AS sessions FROM sessions WHERE $__timeFilter(started_at) GROUP BY status ORDER BY status",
          "refId": "A"
        }
      ],
      "title": "Sessions by status",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 11,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT id, started_at, ended_at, status, EXTRACT(EPOCH FROM (ended_at - started_at)) AS duration_s, CASE WHEN log_messages::text ILIKE '%Stop%' THEN 'close' WHEN log_messages::text ILIKE '%New%' THEN 'open' WHEN log_messages::text ILIKE '%Update%' OR log_messages::text ILIKE '%Recalibrate%' OR log_messages::text ILIKE '%Re-anchor%' THEN 'update' ELSE '-' END AS activity FROM sessions ORDER BY started_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent sessions",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 49 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT unnest(string_to_array(log_messages, E'\\n')) AS log FROM sessions WHERE id = (SELECT MAX(id) FROM sessions) AND log_messages IS NOT NULL",
          "refId": "A"
        }
      ],
      "title": "Last session log",
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["botc", "trading"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "postgres", "uid": "botc-postgres" },
        "definition": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "pair",
        "options": [],
        "query": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Pair"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BoTC Overview",
  "uid": "botc-overview",
  "version": 1
}
